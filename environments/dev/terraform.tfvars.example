environment = "dev"
vpc_cidr    = "172.32.0.0/16"
region      = "us-west-2"
# The DB master password is generated and stored in AWS Secrets Manager by the
# `secrets` module (secret: cloudcart-<env>-db-password) — no password here.
repository_names = ["dev-repo1", "dev-repo2", "dev-repo3", "dev-repo4", "dev-repo5", "dev-repo6", "dev-repo7", "dev-repo8"]
